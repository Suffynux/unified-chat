# ---- Supabase (required to do anything useful) ----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — used by API routes, never shipped to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Meta (ONE app serves both Messenger and Instagram) ----
# App secret, used to verify x-hub-signature-256 on /api/webhook
FB_APP_SECRET=
# Any string you choose; must match the value entered in the Meta webhook config
FB_VERIFY_TOKEN=
# Page access token; sends for both Messenger (PSID) and Instagram (IGSID)
FB_PAGE_ACCESS_TOKEN=
GRAPH_API_VERSION=v23.0

# ---- Email ----
# HMAC secret for the generic inbound webhook (/api/email/inbound).
# If empty, unsigned requests are accepted in development only.
EMAIL_WEBHOOK_SECRET=
RESEND_API_KEY=
# e.g. "Acme Support <support@mail.example.com>"
EMAIL_FROM_ADDRESS=
# Domain used for the plus-addressed reply-to: support+<conversationId>@<domain>
EMAIL_REPLY_DOMAIN=
